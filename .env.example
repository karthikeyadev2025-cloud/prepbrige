# PrepBridge Environment Variables — Example
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# ─── Gemini AI ────────────────────────────────────────
VITE_GEMINI_API_KEY=

# ─── Firebase ────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# ─── Supabase (Client-safe — VITE_ prefix OK) ─────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_BUCKET=profile_photos

# ─── Supabase (SERVER-SIDE ONLY — no VITE_ prefix) ───
SUPABASE_SERVICE_ROLE_KEY=

# ─── Razorpay (Client-safe — public key only) ─────────
VITE_RAZORPAY_KEY=

# ─── Razorpay (SERVER-SIDE ONLY — no VITE_ prefix) ───
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
